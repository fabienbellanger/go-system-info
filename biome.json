{
    "$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
    "formatter": {
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "javascript": {
        "formatter": {
            "indentWidth": 2
        }
    },
    "linter": {
        "rules": {
            "recommended": true
        }
    },
    "files": {
        "includes": ["public/**"]
    }
}
